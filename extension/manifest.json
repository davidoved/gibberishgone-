{
  "manifest_version": 3,
  "name": "GibberishGone - Universal Input Recovery",
  "short_name": "GibberishGone",
  "version": "1.1.0",
  "description": "Instantly restore text typed in the wrong keyboard layout on any website. 80+ layouts. 100% client-side. Zero network.",
  "permissions": [
    "clipboardWrite",
    "activeTab",
    "storage",
    "contextMenus",
    "scripting"
  ],
  "optional_permissions": [
    "clipboardRead"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "GibberishGone - Fix Wrong Keyboard Layout",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "options.html",
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+G"
      },
      "description": "Open GibberishGone popup"
    },
    "fix-selection": {
      "suggested_key": {
        "default": "Alt+Shift+F"
      },
      "description": "Fix selected text on current page"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'none';"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png", "icons/*.svg"],
      "matches": ["<all_urls>"]
    }
  ],
  "author": "GibberishGone Team",
  "homepage_url": "https://gibberishgone.vercel.app"
}
